        // Build precise system prompt rules for the API call
        function buildStructuredQuery(notes) {
            const history = document.getElementById('input-history').value || "None specified";
            const stage = document.getElementById('input-stage').value;

            return `You are Daniel Reyes' elite AI Thought Partner and Senior Logistics Strategist.
Perform a complete, structured analysis on the raw meeting/call logs provided.

RAW NOTES:
"""${notes}"""

CONTEXT:
- Current CRM Stage: ${stage}
- Historical Client Context: ${history}

OUTPUT REQUIRED:
You must provide your analysis in the exact JSON format below. Do not add conversational text outside the JSON.

{
  "summary": "A concise, objective 3-sentence summary of the shipment requirements. List any missing details as 'Not specified'.",
  "actions": [
    "Action Item 1",
    "Action Item 2"
  ],
  "email": "A professional, direct, non-fluff email draft (under 4 lines) ready to send to the contact. Use a friendly but action-oriented voice.",
  "probability": 75,
  "probability_rationale": "Clear reasoning detailing the conversion likelihood estimate based on the raw text.",
  "risk_assessment": "Operational risk analysis using specific textual evidence from the notes.",
  "scheduling_recommendation": "Suggested follow-up timeline for dispatchers.",
  "crm_suggestions": {
    "deal_stage": "Suggested pipeline stage",
    "notes_field": "Short summary for CRM notes field",
    "risk_flag": "Yes/No"
  },
  "executive_brief": "A strategic brief for Daniel Reyes focusing on cash flow, potential expedited pricing leverage, and margin preservation (under 10 lines)."
}`;
        }

        // Exponential backoff logic
        async function callGeminiWithRetry(apiKey, prompt, retries = 5, delay = 1000) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                generationConfig: { responseMimeType: "application/json" }
            };

            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (response.ok) {
                        const data = await response.json();
                        return data.candidates?.[0]?.content?.parts?.[0]?.text || "{}";
                    }
                } catch (e) {
                    if (i === retries - 1) throw e;
                }
                await new Promise(res => setTimeout(res, delay));
                delay *= 2; // scale step
            }
            throw new Error("API call failed");
        }

        // Render standard Live JSON response
        function renderLiveAIResults(rawJsonText) {
            try {
                // Parse clean JSON outputted by Gemini 2.5 structured schema
                const cleanJson = JSON.parse(rawJsonText.replace(/```json/g, '').replace(/```/g, ''));
                buildResponseUI(cleanJson);
            } catch (err) {
                console.error("JSON parsing failed, falling back to clean text parser", err);
                const fallbackObj = {
                    summary: "Successfully executed the intelligence query but encountered structured JSON mapping differences. Please verify output fields.",
                    actions: ["Review raw API payload logs for exact fields"],
                    email: "Unable to generate exact visual structure. Real-time API fallback activated.",
                    probability: 50,
                    probability_rationale: "Review api parsing limits.",
                    risk_assessment: "Data processing variance.",
                    scheduling_recommendation: "Immediate overview suggested.",
                    crm_suggestions: { deal_stage: "Review", notes_field: "N/A", risk_flag: "Unknown" },
                    executive_brief: rawJsonText
                };
                buildResponseUI(fallbackObj);
            }
        }

