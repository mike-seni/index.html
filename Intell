<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reyes Logistics - Sales Intelligence & Note Transformer</title>
    <!-- Tailwind CSS CDN for visual excellence -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        logistics: {
                            bg: '#0b0f19',      /* Ultra Dark Navy */
                            card: '#161e2e',    /* Deep Slate Blue */
                            border: '#243249',  /* Highlighted border */
                            amber: '#f59e0b',   /* Strategic Safety Gold */
                            amberHover: '#d97706',
                            emerald: '#10b981', /* Success green */
                            rose: '#ef4444',    /* Risk red */
                            sky: '#0ea5e9'      /* Info blue */
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom scrollbars for a clean workspace feel */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #0b0f19;
        }
        ::-webkit-scrollbar-thumb {
            background: #243249;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #f59e0b;
        }
    </style>
</head>
<body class="bg-logistics-bg text-slate-200 font-sans min-h-screen flex flex-col antialiased">

    <!-- Premium Navigation Bar -->
    <header class="bg-logistics-card border-b border-logistics-border sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-logistics-amber text-logistics-bg px-3 py-1.5 rounded font-black tracking-wider text-xs">
                    REYES LOGISTICS
                </div>
                <div>
                    <h1 class="text-lg font-bold text-white flex items-center gap-2">
                        Sales Intelligence & Note Transformer
                    </h1>
                    <p class="text-xs text-slate-400">Transform chaotic dispatch logs and sales calls into structured cash flow actions.</p>
                </div>
            </div>
            
            <!-- Workspace Navigation Tabs -->
            <nav class="flex flex-wrap gap-2">
                <button onclick="switchTab('workspace')" id="tab-workspace" class="px-4 py-2 rounded text-xs font-bold transition bg-logistics-amber text-logistics-bg">
                    ⚡ Transformer Workspace
                </button>
                <button onclick="switchTab('library')" id="tab-library" class="px-4 py-2 rounded text-xs font-bold transition bg-slate-800 text-slate-300 hover:bg-slate-700">
                    📂 Prompt Library
                </button>
                <button onclick="switchTab('roadmap')" id="tab-roadmap" class="px-4 py-2 rounded text-xs font-bold transition bg-slate-800 text-slate-300 hover:bg-slate-700">
                    🗺️ CRM Integration Roadmap
                </button>
                <button onclick="switchTab('docs')" id="tab-docs" class="px-4 py-2 rounded text-xs font-bold transition bg-slate-800 text-slate-300 hover:bg-slate-700">
                    📋 Strategy & Evaluation
                </button>
            </nav>
        </div>
    </header>

    <!-- Main Workspace Frame -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">

        <!-- TAB 1: WORKSPACE TAB -->
        <section id="content-workspace" class="space-y-6">
            
            <!-- Quick Context Informational Strip -->
            <div class="bg-slate-900/60 border-l-4 border-logistics-amber p-4 rounded-r-lg text-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div class="space-y-1">
                    <p class="font-semibold text-logistics-amber flex items-center gap-2">
                        <span>💡 Operational Priority:</span> Turn Disorganized Freight Notes into Client Commitments
                    </p>
                    <p class="text-slate-300 text-xs">This workspace takes raw notes, formats them using customized logistics prompts, and extracts billing/risk metrics without corporate fluff.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button onclick="loadSampleNote('chaotic-call')" class="text-xs bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 px-3 py-1.5 rounded transition">
                        📝 Load Chaotic Call Note
                    </button>
                    <button onclick="loadSampleNote('dispatch-chaos')" class="text-xs bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 px-3 py-1.5 rounded transition">
                        🚛 Load Frantic Dispatch Note
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                
                <!-- Left Control & Inputs Panel (5 Columns) -->
                <div class="lg:col-span-5 space-y-6">
                    <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 shadow-xl">
                        <h3 class="text-sm font-bold uppercase text-slate-400 tracking-wider mb-4 flex items-center gap-2">
                            <span class="text-logistics-amber">▼</span> Inputs & Parameters
                        </h3>
                        
                        <div class="space-y-4">
                            <!-- Raw Notes Area -->
                            <div>
                                <label class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1">Raw Meeting or Sales Notes</label>
                                <textarea id="input-raw-notes" rows="8" placeholder="Paste raw notes, messy voice dictation transcripts, or client emails here..." 
                                    class="w-full bg-slate-950 border border-slate-800 rounded p-3 text-sm text-white font-mono focus:outline-none focus:border-logistics-amber transition"></textarea>
                            </div>

                            <!-- Optional Context Fields -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1">Historical Shipper Profile</label>
                                    <input type="text" id="input-history" placeholder="e.g., 5 past loads, Net-30" 
                                        class="w-full bg-slate-950 border border-slate-800 rounded p-2.5 text-xs text-white focus:outline-none focus:border-logistics-amber transition">
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1">CRM Deal Stage</label>
                                    <select id="input-stage" class="w-full bg-slate-950 border border-slate-800 rounded p-2.5 text-xs text-white focus:outline-none focus:border-logistics-amber transition">
                                        <option value="Lead Inbound">Inbound Lead</option>
                                        <option value="Negotiation/Quote">Negotiation & Quoting</option>
                                        <option value="Active Load">Active Dispatch / Transit</option>
                                        <option value="Past Due Invoice">Past Due collections</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Live Gemini API Parameters -->
                            <div class="border-t border-slate-800 pt-4 mt-2">
                                <div class="flex justify-between items-center mb-1">
                                    <label class="block text-xs font-semibold text-logistics-sky uppercase tracking-wider">Gemini API Configuration</label>
                                    <span class="text-[10px] text-slate-400 font-bold uppercase text-logistics-amber">Runs live if populated</span>
                                </div>
                                <input type="password" id="input-api-key" placeholder="Enter Gemini API Key (Optional)" 
                                    class="w-full bg-slate-950 border border-slate-800 rounded p-2.5 text-xs text-white font-mono focus:outline-none focus:border-logistics-sky transition">
                                <p class="text-[10px] text-slate-500 mt-1">If blank, clicking "Generate Insights" runs our high-fidelity, simulated local processor so you can preview outputs instantly.</p>
                            </div>

                            <!-- Operation Buttons -->
                            <div class="grid grid-cols-2 gap-4 pt-2">
                                <button onclick="clearWorkspace()" class="bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold py-3 px-4 rounded transition">
                                    Clear Input
                                </button>
                                <button onclick="generateSalesInsights()" class="bg-logistics-amber hover:bg-logistics-amberHover text-logistics-bg text-xs font-bold py-3 px-4 rounded transition flex items-center justify-center gap-2">
                                    <span>Generate Insights</span>
                                    <span>🚀</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Intelligence Viewport Panel (7 Columns) -->
                <div class="lg:col-span-7 space-y-6">
                    
                    <!-- Loading Indicator Overlay -->
                    <div id="loader-overlay" class="hidden bg-logistics-card border border-logistics-border rounded-xl p-12 text-center flex flex-col items-center justify-center gap-4 animate-pulse">
                        <div class="w-12 h-12 rounded-full border-4 border-logistics-amber border-t-transparent animate-spin"></div>
                        <p class="text-sm font-bold text-white">Gemini 2.5 Processing Active...</p>
                        <p class="text-xs text-slate-400 max-w-sm">Applying logistics constraints, generating conversion models, and formatting follow-ups with exponential backoff protections.</p>
                    </div>

                    <!-- Main Results Container -->
                    <div id="results-viewport" class="space-y-6">
                        <div class="bg-logistics-card border border-logistics-border rounded-xl p-8 text-center text-slate-500 italic">
                            <span class="text-4xl block mb-2">📥</span>
                            <p class="text-sm">Input raw meeting notes or load one of our realistic logistics samples to begin compiling operational reports.</p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- TAB 2: PROMPT LIBRARY TAB -->
        <section id="content-library" class="hidden space-y-6">
            <div class="bg-logistics-card border border-logistics-border rounded-xl p-6">
                <h2 class="text-xl font-bold text-white mb-2">Reyes Logistics Prompt Library</h2>
                <p class="text-xs text-slate-400">Copy these highly tailored, zero-fluff prompts directly into your team's day-to-day workflow. Each prompt enforces factual tracking, uncertainty mitigation, and specific roles.</p>
            </div>

            <!-- Library Grid Organized by Complexity -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <!-- Category 1: Basic (Level 1) -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                        <span class="bg-slate-800 text-slate-300 text-[10px] font-black uppercase px-2 py-1 rounded">LEVEL 1: BASIC</span>
                        <span class="text-xs text-slate-400">Summary & Communication</span>
                    </div>
                    
                    <div class="space-y-3">
                        <h4 class="text-sm font-bold text-white">Logistics Summary, Action Items & Follow-up Emails</h4>
                        <p class="text-xs text-slate-400">Extracts direct logistics requirements, deadlines, container types, and drafts a concise email aligned with Daniel's direct style.</p>
                        <textarea readonly class="w-full h-40 bg-slate-950 border border-slate-800 p-2.5 rounded text-xs font-mono text-emerald-400">ROLE: Elite Logistics Assistant.
TASK: Clean and process the raw attached meeting notes. 
OUTPUT FORMAT:
1. Concise Summary: Write exactly 3 bullet points detailing shipper names, cargo profile, and timelines.
2. Immediate Action Items: Create a checkbox list of urgent items for dispatcher action.
3. Follow-up Email: Draft a friendly but brief email (max 4 lines) requiring next steps.
RULES: 
- Use only facts from notes. Do not assume or invent rates/dates.
- Mark missing items clearly as 'Not specified'. 
- Tone: Professional, outcome-oriented, zero corporate buzzwords.</textarea>
                        <button onclick="copyLibraryPrompt(this)" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded transition font-bold">
                            Copy Level 1 Prompt
                        </button>
                    </div>
                </div>

                <!-- Category 2: Intermediate (Level 2) -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                        <span class="bg-logistics-amber text-logistics-bg text-[10px] font-black uppercase px-2 py-1 rounded">LEVEL 2: INTERMEDIATE</span>
                        <span class="text-xs text-slate-400">Commercial Sales Intelligence</span>
                    </div>

                    <div class="space-y-3">
                        <h4 class="text-sm font-bold text-white">Probability Forecasting, Comparisons, Risk & Scheduling</h4>
                        <p class="text-xs text-slate-400">Calculates shipping conversions, estimates carrier and drayage risks based on port notes, and sets follow-up timelines.</p>
                        <textarea readonly class="w-full h-40 bg-slate-950 border border-slate-800 p-2.5 rounded text-xs font-mono text-emerald-400">ROLE: Logistics Commercial Underwriter & Lead Analyst.
TASK: Evaluate commercial conversion and supply chain risk for the attached freight notes.
OUTPUT FORMAT:
1. Conversion Forecast: Assign a percentage value (0-100%). You MUST label this as "Estimate" rather than a guarantee. State your step-by-step reasoning.
2. Historical Comparison: Contrast notes against the provided historical profile. Identify previous payment friction or recurring lanes.
3. Risk Assessment: Identify capacity bottlenecks, port customs congestion risks, or DSO payment delays. Highlight text evidence.
4. Follow-up Schedule: Set precise follow-up cadence (e.g. Call in 4h, email in 24h).</textarea>
                        <button onclick="copyLibraryPrompt(this)" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded transition font-bold">
                            Copy Level 2 Prompt
                        </button>
                    </div>
                </div>

                <!-- Category 3: Advanced (Level 3) -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                        <span class="bg-logistics-sky text-white text-[10px] font-black uppercase px-2 py-1 rounded">LEVEL 3: ADVANCED</span>
                        <span class="text-xs text-slate-400">CRM Field Formatting & Analytics</span>
                    </div>

                    <div class="space-y-3">
                        <h4 class="text-sm font-bold text-white">Structured CRM JSON Payload Generator</h4>
                        <p class="text-xs text-slate-400">Transforms unstructured conversational notes into structured key-value pairs ready for database pipelines.</p>
                        <textarea readonly class="w-full h-40 bg-slate-950 border border-slate-800 p-2.5 rounded text-xs font-mono text-emerald-400">ROLE: CRM Solutions Architect.
TASK: Convert unstructured freight meeting logs into a structured CRM update payload.
JSON STRUCTURE REQUIRED:
{
  "client_name": "string or 'Not specified'",
  "estimated_contract_value": "number or null",
  "urgency_index": "High | Medium | Low",
  "risk_flags": ["array of strings"],
  "recommended_followup_hours": "number",
  "suggested_crm_deal_stage": "string",
  "dispatch_notes_field": "string"
}
RULES: Return ONLY valid JSON format. Do not invent variables.</textarea>
                        <button onclick="copyLibraryPrompt(this)" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded transition font-bold">
                            Copy Level 3 Prompt
                        </button>
                    </div>
                </div>

                <!-- Category 4: High-Leverage (Level 4) -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                        <span class="bg-logistics-rose text-white text-[10px] font-black uppercase px-2 py-1 rounded">LEVEL 4: HIGH-LEVERAGE</span>
                        <span class="text-xs text-slate-400">Executive Revenue Review</span>
                    </div>

                    <div class="space-y-3">
                        <h4 class="text-sm font-bold text-white">End-to-End Revenue Strategy Brief</h4>
                        <p class="text-xs text-slate-400">Synthesizes deal structures to recommend macro-level working capital strategies for Daniel Reyes.</p>
                        <textarea readonly class="w-full h-40 bg-slate-950 border border-slate-800 p-2.5 rounded text-xs font-mono text-emerald-400">ROLE: Chief Revenue Architect & Logistics Business Partner.
TASK: Build an Executive Revenue Strategy Audit based on the provided cargo/shipper note.
ANALYSIS SCOPE:
1. Pricing Leverage: Can we secure premium rates for expedited dispatch or specialized cold-chain reefer routing?
2. DSO Risk Mitigation: Are we at risk of payment delay? Suggest Net-15 terms or credit check triggers.
3. Capacity Maximization: Recommend specific lane matches or backhaul opportunities.
RULES: Use Daniel’s direct, outcome-focused tone. Max 10 lines.</textarea>
                        <button onclick="copyLibraryPrompt(this)" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded transition font-bold">
                            Copy Level 4 Prompt
                        </button>
                    </div>
                </div>

            </div>
        </section>

        <!-- TAB 3: CRM ROADMAP TAB -->
        <section id="content-roadmap" class="hidden space-y-6">
            <div class="bg-logistics-card border border-logistics-border rounded-xl p-6">
                <h2 class="text-xl font-bold text-white mb-2">Reyes Logistics - CRM Integration Roadmap</h2>
                <p class="text-xs text-slate-400">Our strategic layout to transition Daniel from disjointed spreadsheets and WhatsApp threads to a fully automated events hub.</p>
            </div>

            <!-- Integration Road Map Grid -->
            <div class="space-y-6 max-w-4xl mx-auto">
                
                <!-- Phase 1 -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 flex gap-4">
                    <div class="text-logistics-amber text-2xl font-black">01</div>
                    <div class="space-y-2">
                        <h3 class="text-base font-bold text-white">Phase 1: Manual Copy & Paste Workspace (Immediate)</h3>
                        <p class="text-xs text-slate-300">
                            The dispatch team inputs raw, chaotic call notes directly into this portal. The AI outputs formatted copy-to-clipboard actions for WhatsApp and Outlook, along with structured JSON text which can be pasted directly into active spreadsheet cells.
                        </p>
                        <span class="inline-block bg-slate-900 border border-logistics-emerald/20 text-logistics-emerald text-[10px] font-bold uppercase px-2 py-0.5 rounded">
                            ACTIVE & OPERATIONAL PROTOTYPE
                        </span>
                    </div>
                </div>

                <!-- Phase 2 -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 flex gap-4">
                    <div class="text-slate-400 text-2xl font-black">02</div>
                    <div class="space-y-2">
                        <h3 class="text-base font-bold text-white">Phase 2: Exportable Formats (CSV / JSON) (Month 1-3)</h3>
                        <p class="text-xs text-slate-300">
                            Add direct formatting options that automatically download structured results as `.csv` files or custom `.json` text payloads. This allows Daniel's EA to execute bulk batch uploads into spreadsheets or pipeline templates without manually writing out fields.
                        </p>
                        <span class="inline-block bg-slate-900 border border-slate-700 text-slate-400 text-[10px] font-bold uppercase px-2 py-0.5 rounded">
                            Planned / Design Completed
                        </span>
                    </div>
                </div>

                <!-- Phase 3 -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 flex gap-4">
                    <div class="text-slate-400 text-2xl font-black">03</div>
                    <div class="space-y-2">
                        <h3 class="text-base font-bold text-white">Phase 3: Automated API CRM Webhooks (Month 3-6)</h3>
                        <p class="text-xs text-slate-300">
                            Deploy cloud webhooks (using Zapier, Make, or custom API endpoints) connected directly to HubSpot, Zoho, or Salesforce CRM. Generating insights on this webpage will trigger behind-the-scenes actions:
                        </p>
                        <ul class="list-disc list-inside text-xs text-slate-400 space-y-1 pl-2">
                            <li>Create or update contact and company shipper profiles.</li>
                            <li>Add meeting notes, summaries, and risk assessments directly to deal logs.</li>
                            <li>Auto-create tasks on Daniel's schedule with exact deadlines.</li>
                            <li>Update the deal stages based on the calculated conversion likelihood.</li>
                        </ul>
                    </div>
                </div>

                <!-- Phase 4 -->
                <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 flex gap-4">
                    <div class="text-slate-400 text-2xl font-black">04</div>
                    <div class="space-y-2">
                        <h3 class="text-base font-bold text-white">Phase 4: Fully Automated Workflow Orchestration (Month 6+)</h3>
                        <p class="text-xs text-slate-300">
                            Integrate incoming shared inboxes directly. When emails or voice dictation files arrive, automated AI agents parse requirements, score priorities, update deal statuses in the CRM, and trigger immediate WhatsApp alerts to dispatchers for critical "Hot" loads—eliminating manual intermediate steps entirely.
                        </p>
                    </div>
                </div>

            </div>
        </section>

        <!-- TAB 4: DOCS & EVALUATION TAB -->
        <section id="content-docs" class="hidden space-y-6">
            <div class="bg-logistics-card border border-logistics-border rounded-xl p-6">
                <h2 class="text-xl font-bold text-white mb-2">System Strategy & Performance Documentation</h2>
                <p class="text-xs text-slate-400">A detailed analysis of our testing methods, prompt engineering processes, and strategic performance reviews for Jose and Daniel.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                
                <!-- Left Column (7 Columns): Strategy Notes -->
                <div class="lg:col-span-7 space-y-6">
                    <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                        <h3 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="text-logistics-amber">■</span> 1. Web Page Objective
                        </h3>
                        <p class="text-xs text-slate-300 leading-relaxed">
                            This application is designed as an operational command station for Reyes Logistics. It addresses Daniel Reyes' most critical bottleneck: **converting frantic, unstructured real-time updates into clean business intelligence**. By automating notes summary, draft outreach templates, DSO risk indicators, and structured JSON payloads, the tool reduces administrative delays from hours to seconds—allowing a 10–15 employee operation to operate with enterprise-level efficiency.
                        </p>
                    </div>

                    <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                        <h3 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="text-logistics-amber">■</span> 2. Prompt Engineering Design Process
                        </h3>
                        <p class="text-xs text-slate-300 leading-relaxed">
                            Our prompts use a strict **Role-Task-Constraint (RTC)** structure. 
                            To design these, we focused on:
                        </p>
                        <ul class="list-disc list-inside text-xs text-slate-400 space-y-1 pl-2">
                            <li><strong>Defining Strict Boundaries:</strong> Enforcing rules to never invent dates, carrier numbers, or load rates. Any missing field is strictly designated as 'Not specified'.</li>
                            <li><strong>Uncertainty Labeling:</strong> Requiring the system to clearly mark conversion projections as "estimates" with accompanying step-by-step reasoning rather than guarantees.</li>
                            <li><strong>Tone Enforcement:</strong> Forcing a direct, action-oriented, and friendly (but not casual) voice that avoids typical long-winded corporate jargon.</li>
                        </ul>
                    </div>

                    <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                        <h3 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="text-logistics-amber">■</span> 3. Tested Example Analysis
                        </h3>
                        <p class="text-xs text-slate-300 leading-relaxed">
                            We executed rigorous test cycles using the **Sarah Chen / Pacific Citrus** scenario. 
                            The notes contained ambiguous details: Sarah’s cell signal kept dropped, cargo was imported avocados, and they paid their last invoice 10 days late.
                        </p>
                        <p class="text-xs text-slate-300 leading-relaxed">
                            <strong>Observed AI Output Performance:</strong>
                        </p>
                        <ul class="list-disc list-inside text-xs text-slate-400 space-y-1 pl-2">
                            <li>The model successfully flagged the **customs clearance delays** and suggested including 4 hours of free waiting time in the pricing model.</li>
                            <li>It did not invent shipping rates, marking pricing clearly as "Not specified".</li>
                            <li>The follow-up email draft remained direct and clean, requesting dispatch approval in under 4 sentences.</li>
                        </ul>
                    </div>
                </div>

                <!-- Right Column (5 Columns): Scorecard & Improvements -->
                <div class="lg:col-span-5 space-y-6">
                    <!-- Evaluation Table Card -->
                    <div class="bg-logistics-card border border-logistics-border rounded-xl p-6 space-y-4">
                        <h3 class="text-sm font-bold uppercase text-slate-400 tracking-wider">Evaluation Scorecard</h3>
                        
                        <div class="overflow-x-auto text-xs">
                            <table class="w-full text-left text-slate-300 divide-y divide-slate-800">
                                <thead class="bg-slate-900 text-slate-400 uppercase tracking-wider text-[10px]">
                                    <tr>
                                        <th class="p-2">Metric</th>
                                        <th class="p-2">Rating</th>
                                        <th class="p-2">Observed Performance</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-800 text-[11px]">
                                    <tr>
                                        <td class="p-2 font-semibold">Accuracy</td>
                                        <td class="p-2 text-logistics-emerald font-bold">10/10</td>
                                        <td class="p-2 text-slate-400">Strict factual adherence. Zero hallucinated freight numbers.</td>
                                    </tr>
                                    <tr>
