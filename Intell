            if (apiKey) {
                // RUN LIVE GEMINI AI WITH RETRY BLOCK & EXPONENTIAL BACKOFF
                try {
                    const prompt = buildStructuredQuery(rawNotes);
                    const responseText = await callGeminiWithRetry(apiKey, prompt);
                    renderLiveAIResults(responseText);
                } catch (err) {
                    console.error(err);
                    alert("Gemini call fell behind. Activating local fallback sandbox execution instantly.");
                    renderSimulatedResults(rawNotes);
                } finally {
                    loader.classList.add('hidden');
                    results.classList.remove('hidden');
                }
            } else {
                // RUN HIGH-FIDELITY SIMULATOR
