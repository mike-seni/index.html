        // Trigger dynamic AI call (with high-fidelity simulated fallback)
        async function generateSalesInsights() {
            const rawNotes = document.getElementById('input-raw-notes').value.trim();
            if (!rawNotes) {
                alert("Please enter some raw notes or click one of the load samples buttons to proceed.");
                return;
